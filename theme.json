{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"layout": {
			"contentSize": "760px",
			"wideSize": "1120px"
		},
		"color": {
			"palette": [
				{
					"name": "Accent",
					"slug": "accent",
					"color": "#0a6f5a"
				},
				{
					"name": "Text",
					"slug": "text",
					"color": "#1d2327"
				},
				{
					"name": "Surface",
					"slug": "surface",
					"color": "#f6f7f9"
				}
			]
		},
		"typography": {
			"fluid": false,
			"fontFamilies": [
				{
					"name": "System Sans",
					"slug": "system-sans",
					"fontFamily": "-apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Oxygen-Sans, Ubuntu, Cantarell, \"Helvetica Neue\", sans-serif"
				}
			]
		}
	},
	"styles": {
		"color": {
			"background": "#ffffff",
			"text": "#1d2327"
		},
		"typography": {
			"fontFamily": "var:preset|font-family|system-sans",
			"lineHeight": "1.7"
		}
	}
}
